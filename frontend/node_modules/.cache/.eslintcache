sing-React-Js/frontend/src/utils/icons.js",[],[],"/home/juan-uni/Documentos/universidad/Bb-proyectos/Expense-tracker-app-using-React-Js/frontend/src/utils/menuItems.js",[],[],"/home/juan-uni/Documentos/universidad/Bb-proyectos/Expense-tracker-app-using-React-Js/frontend/src/History/History.js",[],[],"/home/juan-uni/Documentos/universidad/Bb-proyectos/Expense-tracker-app-using-React-Js/frontend/src/Components/Chart/Chart.js",[],[],"/home/juan-uni/Documentos/universidad/Bb-proyectos/Expense-tracker-app-using-React-Js/frontend/src/Components/IncomeItem/IncomeItem.js",[],[],"/home/juan-uni/Documentos/universidad/Bb-proyectos/Expense-tracker-app-using-React-Js/frontend/src/Components/Form/Form.js",[],[],"/home/juan-uni/Documentos/universidad/Bb-proyectos/Expense-tracker-app-using-React-Js/frontend/src/utils/dateFormat.js",[],[],"/home/juan-uni/Documentos/universidad/Bb-proyectos/Expense-tracker-app-using-React-Js/frontend/src/Components/Button/Button.js",[],[],"/home/juan-uni/Documentos/universidad/Bb-proyectos/Basededatosavanzadas/frontend/src/index.js",[],[],"/home/juan-uni/Documentos/universidad/Bb-proyectos/Basededatosavanzadas/frontend/src/App.js",[],[],"/home/juan-uni/Documentos/universidad/Bb-proyectos/Basededatosavanzadas/frontend/src/styles/GlobalStyle.js",[],[],"/home/juan-uni/Documentos/universidad/Bb-proyectos/Basededatosavanzadas/frontend/src/context/globalContext.js",[],[],"/home/juan-uni/Documentos/universidad/Bb-proyectos/Basededatosavanzadas/frontend/src/styles/Layout.js",[],[],"/home/juan-uni/Documentos/universidad/Bb-proyectos/Basededatosavanzadas/frontend/src/Components/Navigation/Navigation.js",[],[],"/home/juan-uni/Documentos/universidad/Bb-proyectos/Basededatosavanzadas/frontend/src/Components/Orb/Orb.js",[],[],"/home/juan-uni/Documentos/universidad/Bb-proyectos/Basededatosavanzadas/frontend/src/Components/Expenses/Expenses.js",["213","214"],[],"import React, { useEffect } from 'react'\nimport styled from 'styled-components';\nimport { InnerLayout } from '../../styles/Layout';\nimport { useGlobalContext } from '../../context/globalContext';\nimport IncomeItem from '../IncomeItem/IncomeItem';\nimport ExpenseForm from './ExpenseForm';\n\nfunction Expenses() {\n  const {addIncome, expenses, getExpenses, deleteExpense, totalExpenses} = useGlobalContext()\n\n  useEffect(() => {\n      getExpenses()\n  },[])\n  return (\n    <ExpenseStyled>\n        <InnerLayout>\n            <h1>Gastos</h1>\n            <h2 className='total-income'> Total Expense : <span>${totalExpenses()} </span> </h2>\n            <div className=\"income-content\">\n                <div className=\"form-container\">\n                  <ExpenseForm/>\n                </div>\n                <div className=\"incomes\">\n                    {expenses.map((income) => {\n                        const {_id, title, amount, date, category, description,type} = income;\n                        return <IncomeItem\n                        key={_id}\n                        id={_id} \n                        title={title} \n                        description={description} \n                        amount={amount} \n                        date={date} \n                        type={type}\n                        category={category} \n                        indicatorColor=\"var(--color-green)\"\n                        deleteItem={deleteExpense}\n                        \n                        />\n                    })}\n                </div>\n            </div>\n        </InnerLayout>\n    </ExpenseStyled>\n  )\n}\nconst ExpenseStyled = styled.div`\n  display: flex;\n  overflow: auto;\n  .total-income{\n    display: flex;\n    justify-content: center;\n    align-items: center;\n    background: #FCF6F9;\n    border: 2px solid #FFFFFF;\n    box-shadow: 0px 1px 15px rgba(0, 0, 0, 0.06);\n    border-radius: 20px;\n    padding: 1rem;\n    margin: 1rem 0;\n    font-size: 2rem;\n    gap: .5rem;\n    span{\n        font-size: 2.5rem;\n        font-weight: 800;\n        color: var(--color-green);\n      }\n  }\n  .income-content{\n    display:flex;\n    gap:2rem;\n    .incomes{\n      flex:1;\n    }\n  }\n`;\nexport default Expenses",[],"/home/juan-uni/Documentos/universidad/Bb-proyectos/Basededatosavanzadas/frontend/src/Components/Incomes/Incomes.js",["215"],[],"/home/juan-uni/Documentos/universidad/Bb-proyectos/Basededatosavanzadas/frontend/src/Components/Dashboard/Dashboard.js",["216"],[],"/home/juan-uni/Documentos/universidad/Bb-proyectos/Basededatosavanzadas/frontend/src/Components/Expenses/ExpenseForm.js",[],[],"/home/juan-uni/Documentos/universidad/Bb-proyectos/Basededatosavanzadas/frontend/src/utils/useWindowSize.js",[],[],"/home/juan-uni/Documentos/universidad/Bb-proyectos/Basededatosavanzadas/frontend/src/utils/icons.js",[],[],"/home/juan-uni/Documentos/universidad/Bb-proyectos/Basededatosavanzadas/frontend/src/utils/menuItems.js",[],[],"/home/juan-uni/Documentos/universidad/Bb-proyectos/Basededatosavanzadas/frontend/src/History/History.js",[],[],"/home/juan-uni/Documentos/universidad/Bb-proyectos/Basededatosavanzadas/frontend/src/Components/IncomeItem/IncomeItem.js",[],[],"/home/juan-uni/Documentos/universidad/Bb-proyectos/Basededatosavanzadas/frontend/src/Components/Chart/Chart.js",[],[],"/home/juan-uni/Documentos/universidad/Bb-proyectos/Basededatosavanzadas/frontend/src/Components/Form/Form.js",[],[],"/home/juan-uni/Documentos/universidad/Bb-proyectos/Basededatosavanzadas/frontend/src/Components/Button/Button.js",[],[],"/home/juan-uni/Documentos/universidad/Bb-proyectos/Basededatosavanzadas/frontend/src/utils/dateFormat.js",[],[],{"ruleId":"217","severity":1,"message":"218","line":16,"column":15,"nodeType":"219","messageId":"220","endLine":16,"endColumn":23},{"ruleId":"217","severity":1,"message":"221","line":30,"column":15,"nodeType":"219","messageId":"220","endLine":30,"endColumn":18},{"ruleId":"217","severity":1,"message":"218","line":43,"column":15,"nodeType":"219","messageId":"220","endLine":43,"endColu